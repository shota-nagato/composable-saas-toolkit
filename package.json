{
  "name": "toolkit",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -n turso,app -c blue,green \"pnpm dev:turso\" \"turbo run dev\"",
    "dev:turso": "turso dev --db-file .local/local.db",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.22.0",
  "volta": {
    "node": "22.21.1"
  },
  "engines": {
    "node": "22.21.1",
    "pnpm": "10.22.0",
    "npm": "pnpm\u3092\u4f7f\u3063\u3066\u304f\u3060\u3055\u3044"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.3.5",
    "concurrently": "catalog:",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
