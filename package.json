{
  "name": "toolkit",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -n turso,app -c blue,green \"pnpm dev:turso\" \"turbo run dev\"",
    "dev:turso": "turso dev --db-file .local/local.db",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "db:migrate": "pnpm --filter @toolkit/db db:migrate",
    "db:seed": "pnpm --filter @toolkit/db seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.22.0",
  "volta": {
    "node": "22.21.1"
  },
  "engines": {
    "node": "22.21.1",
    "pnpm": "10.22.0",
    "npm": "pnpmを使ってください"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "concurrently": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
