{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded",
      "quoteStyle": "single"
    }
  },
  "linter": {
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noArrayIndexKey": "warn"
      },
      "a11y": {
        "noSvgWithoutTitle": "warn",
        "useButtonType": "warn",
        "useHtmlLang": "warn",
        "noLabelWithoutControl": "warn",
        "useValidAnchor": "warn",
        "noStaticElementInteractions": "warn",
        "useSemanticElements": "warn"
      }
    }
  },
  "css": {
    "linter": { "enabled": false },
    "formatter": { "enabled": false }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/generated",
      "!**/*.d.ts",
      "!**/*.css",
      "!**/migrations",
      "!**/auth.config.ts"
    ]
  }
}
